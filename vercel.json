{
    "builds": [
        {
            "src": "src/api.py",
            "use": "@vercel/python"
        },
        {
            "src": "ai-bill-simulator/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "src/api.py"
        },
        {
            "src": "/(.*)",
            "dest": "ai-bill-simulator/dist/$1"
        }
    ]
}